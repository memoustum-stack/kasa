import streamlit as st
import wikipedia
import random
import time

# --- SİSTEM AYARLARI ---
try:
    wikipedia.set_lang("tr")
except:
    pass

st.set_page_config(page_title="Cnclime v53 | Kardeşlik", page_icon="🤝", layout="wide")

# --- BELLEK SİSTEMİ ---
if 'user' not in st.session_state:
    st.session_state.user = ""
if 'notes' not in st.session_state:
    st.session_state.notes = []

# --- GİRİŞ EKRANI (TANIŞMA) ---
if st.session_state.user == "":
    st.title("🤖 Selam! Ben Cnclime. 🧠")
    st.markdown("### Ekibimize hoş geldin şef! Seninle tanıştığıma çok memnun oldum.")
    st.divider()
    
    name = st.text_input("Senin ismin neydi dostum?", placeholder="İsmini buraya bırak...", key="v53_login")
    if st.button("Ekibe Katıl 🚀"):
        if name:
            st.session_state.user = name.title()
            st.balloons()
            st.success(f"Hoş geldin {st.session_state.user}! Artık sen de bir Cnclime üyesisin.")
            time.sleep(1)
            st.rerun()
    st.stop()

u_name = st.session_state.user

# --- YAN MENÜ ---
with st.sidebar:
    st.title(f"👋 Selam {u_name}!")
    st.info(f"Benim adım **Cnclime**, seninle burada olduğum için çok mutluyum!")
    st.divider()
    mod = st.radio("Bugün n'apıyoruz şef?", [
        "💬 Samimi Sohbet & Moral", 
        "🔐 Gizli Not Kasası",
        "🔢 Sayısal Mantık & Hesap",
        "🎨 Görsel Oluştur (Hayal Et)", 
        "🔍 Akıllı Araştırma (Sohbetli)",
        "👥 Ekip Kadrosu"
    ])
    if st.sidebar.button("Sistemi Kapat"):
        st.session_state.user = ""
        st.rerun()

# --- ANA PANEL ---
st.title(f"🍋 {mod}")
st.divider()

# --- MOD 1: SAMİMİ SOHBET & DESTEK ---
if mod == "💬 Samimi Sohbet & Moral":
    st.write(f"Anlat bakalım {u_name}, bugün neler yapıyoruz? Ben Cnclime, her zaman yanındayım.")
    u_input = st.text_input("Bana bir şeyler yaz:", key="v53_chat")

    if u_input:
        m = u_input.lower().strip()
        if any(x in m for x in ["kötüyüm", "üzgünüm", "moralim bozuk", "canım sıkkın"]):
            st.info(f"🤖 **Cnclime:** Ah be {u_name}, canını sıkan ne varsa anlat bana. Ben senin dostunum. Gel bir nefes alalım, beraber çözelim.")
        elif any(x in m for x in ["selam", "sa", "nbr", "naber"]):
            st.success(f"🤖 **Cnclime:** Aleykümselam {u_name}! Ben Cnclime, tanıştığımıza tekrar memnun oldum. Keyifler nasıl?")
        else:
            with st.spinner("Dinliyorum..."):
                time.sleep(0.4)
                st.write(f"🤖 **Cnclime:** Valla {u_name}, seni çok iyi anlıyorum. Anlatmaya devam et, araştırmalarla kafanı şişirmem!")

# --- MOD 2: GİZLİ NOT KASASI ---
elif mod == "🔐 Gizli Not Kasası":
    st.write(f"Bak {u_name}, burası ekibin özel alanı. Giriş için anahtar lazım!")
    sifre = st.text_input("Ekip Anahtarını Gir:", type="password")
    
    if sifre == "cnclime2026": # Şifre sabit kaldı şef
        st.success("✅ Anahtar Doğru! Hoş geldin şef.")
        tab1, tab2 = st.tabs(["📝 Not Ekle", "📜 Notları Oku"])
        with tab1:
            yeni_not = st.text_area("Gizli notunu buraya bırak:")
            if st.button("Kasaya Kilitle 🔒"):
                if yeni_not:
                    st.session_state.notes.append(f"{u_name}: {yeni_not}")
                    st.toast("Not güvenli bir şekilde saklandı!", icon="🔐")
        with tab2:
            if st.session_state.notes:
                for n in st.session_state.notes[::-1]:
                    st.info(f"📌 {n}")
            else: st.write("Kasa boş şef.")
    elif sifre != "":
        st.error("🤖 **Cnclime:** Bu anahtar yanlış! Sen bizim ekipten değilsin galiba?")

# --- MOD 3: SAYISAL MANTIK & HESAP ---
elif mod == "🔢 Sayısal Mantık & Hesap":
    mat_input = st.text_input("Hesaplanacak işlem:", key="v53_math")
    if mat_input:
        try:
            sonuc = eval(mat_input.replace('x', '*'))
            st.success(f"🤖 **Cnclime:** Bak {u_name}, bu işlemin sonucu: **{sonuc}**")
        except: st.error("Hesaplayamadım şef.")

# --- MOD 4: GÖRSEL OLUŞTUR ---
elif mod == "🎨 Görsel Oluştur (Hayal Et)":
    prompt = st.text_input("Hayalini buraya yaz:", key="v53_img")
    if prompt:
        with st.spinner("Hayal ediyorum..."):
            st.image(f"https://loremflickr.com/800/400/{prompt}", caption=f"{u_name} için hayal edilen: {prompt}")

# --- MOD 5: AKILLI ARAŞTIRMA ---
elif mod == "🔍 Akıllı Araştırma (Sohbetli)":
    ara = st.text_input("Neyi öğrenelim?", key="v53_ara")
    if ara:
        with st.spinner("Zihnimi tarıyorum..."):
            try:
                res = wikipedia.summary(wikipedia.search(ara)[0], sentences=2)
                st.info(f"🤖 **Cnclime:** Bak {u_name}, bu {ara} mevzusu aslında şöyle: {res}")
            except: st.error("Bulamadım şef.")

# --- MOD 6: EKİP KADROSU ---
elif mod == "👥 Ekip Kadrosu":
    st.balloons()
    st.success("🚀 **Yeni Ekibimiz Hayırlı Olsun!**")
    st.markdown(f"""
    ### 👑 Lider: **Mehmet Emin**
    ### 🔥 Üyeler: 
    * **Emre Can**
    * **Ömer Eymen**
    * **Yunus Emre**
    * **{u_name}** (Ekibe Yeni Katılan Dostumuz)
    
    **🤖 Sistem: Cnclime AI v53**
    """)

st.divider()
st.caption(f"© 2026 Cnclime AI v53 | Kardeşlik Bağı | Kullanıcı: {u_name}")
